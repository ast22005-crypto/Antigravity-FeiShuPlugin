{
  "name": "antigravity-feishu-bot",
  "displayName": "飞书机器人 (Feishu Bot)",
  "description": "飞书双向集成：接收消息 → Antigravity Agent 处理 → 推送结果",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ast22005-crypto/Antigravity-FeiShuPlugin"
  },
  "license": "MIT",
  "publisher": "stone",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "飞书机器人",
      "properties": {
        "feishuBot.appId": {
          "type": "string",
          "default": "",
          "description": "飞书应用 App ID (cli_xxx)",
          "order": 1
        },
        "feishuBot.appSecret": {
          "type": "string",
          "default": "",
          "description": "飞书应用 App Secret",
          "order": 2
        },
        "feishuBot.enabled": {
          "type": "boolean",
          "default": true,
          "description": "启用飞书集成",
          "order": 3
        },
        "feishuBot.projectName": {
          "type": "string",
          "default": "",
          "description": "项目名称（留空则使用工作区文件夹名）",
          "order": 4
        },
        "feishuBot.notifyOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "项目打开时通知飞书",
          "order": 5
        },
        "feishuBot.notifyOnCompletion": {
          "type": "boolean",
          "default": true,
          "description": "Agent 完成后推送结果到飞书",
          "order": 6
        },
        "feishuBot.autoTriggerAgent": {
          "type": "boolean",
          "default": true,
          "description": "收到飞书消息后自动触发 Agent 处理",
          "order": 7
        },
        "feishuBot.triggerCooldown": {
          "type": "number",
          "default": 10,
          "minimum": 3,
          "maximum": 120,
          "description": "自动触发冷却时间（秒），防止短时间内重复触发",
          "order": 8
        },
        "feishuBot.autoRetryOnError": {
          "type": "boolean",
          "default": true,
          "description": "Agent 出错时自动点击 Retry 按钮（Windows / macOS UI Automation）",
          "order": 9
        },
        "feishuBot.autoRetryInterval": {
          "type": "number",
          "default": 15,
          "minimum": 5,
          "maximum": 60,
          "description": "自动重试检测间隔（秒）",
          "order": 10
        },
        "feishuBot.autoRestartThreshold": {
          "type": "number",
          "default": 10,
          "minimum": 3,
          "maximum": 50,
          "description": "连续重试达到此次数后，自动重启 Antigravity（重载 VS Code 窗口）",
          "order": 11
        },
        "feishuBot.managerPort": {
          "type": "number",
          "default": 8045,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Antigravity-Manager 本地 API 端口（用于认证失败时自动切换账号）",
          "order": 12
        },
        "feishuBot.managerApiKey": {
          "type": "string",
          "default": "",
          "description": "Antigravity-Manager API Key（如果 Manager 配置了鉴权则填写）",
          "order": 13
        }
      }
    },
    "commands": [
      {
        "command": "feishu-bot.connect",
        "title": "飞书: 连接",
        "icon": "$(plug)"
      },
      {
        "command": "feishu-bot.disconnect",
        "title": "飞书: 断开连接",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "feishu-bot.sendText",
        "title": "飞书: 发送文本消息"
      },
      {
        "command": "feishu-bot.sendResult",
        "title": "飞书: 发送处理结果"
      },
      {
        "command": "feishu-bot.readMessages",
        "title": "飞书: 读取消息队列"
      },
      {
        "command": "feishu-bot.clearMessages",
        "title": "飞书: 清空消息队列"
      },
      {
        "command": "feishu-bot.triggerAgent",
        "title": "飞书: 手动触发 Agent 处理"
      },
      {
        "command": "feishu-bot.showStatus",
        "title": "飞书: 查看状态"
      },
      {
        "command": "feishu-bot.openSettings",
        "title": "飞书: 打开设置",
        "icon": "$(gear)"
      },
      {
        "command": "feishu-bot.restart",
        "title": "飞书: 重启 Agent / 测试切换账号"
      },
      {
        "command": "feishu-bot.accountData",
        "title": "飞书: 查看账号配额数据"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "feishu-bot-container",
          "title": "飞书消息",
          "icon": "resources/feishu-icon.svg"
        }
      ]
    },
    "views": {
      "feishu-bot-container": [
        {
          "id": "feishu-bot.messages",
          "name": "消息队列"
        },
        {
          "id": "feishu-bot.connectionStatus",
          "name": "连接状态"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "feishu-bot.connect",
          "when": "view == feishu-bot.connectionStatus",
          "group": "navigation"
        },
        {
          "command": "feishu-bot.openSettings",
          "when": "view == feishu-bot.connectionStatus",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepackage": "npm run compile",
    "package": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.30.0"
  }
}
